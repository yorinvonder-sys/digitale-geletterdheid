{
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/agent-hooks/policy.mjs\" user-prompt",
            "timeout": 10,
            "statusMessage": "Loading DGSkills safety workflow"
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/agent-hooks/policy.mjs\" pre-tool",
            "timeout": 10,
            "statusMessage": "Checking DGSkills safety policy"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$CLAUDE_PROJECT_DIR/scripts/agent-hooks/policy.mjs\" post-tool",
            "timeout": 20,
            "statusMessage": "Recording DGSkills verification needs"
          }
        ]
      }
    ],
    "Stop": []
  }
}
