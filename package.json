{
  "name": "ai-lab---future-architect",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/prerender.mjs",
    "build:prod": "vite build --mode production --sourcemap false && node scripts/prerender.mjs",
    "bridge:chatgpt": "node scripts/github-agent-bridge.mjs process-all --agent chatgpt",
    "bridge:claude": "node scripts/github-agent-bridge.mjs process-all --agent claude",
    "bridge:reasonix": "node scripts/github-agent-bridge.mjs process-all --agent reasonix",
    "bridge:comments": "node scripts/github-agent-comments.mjs respond",
    "bridge:comments:dry": "node scripts/github-agent-comments.mjs respond --dry-run",
    "bridge:dry": "node scripts/github-agent-bridge.mjs process-pipeline --dry-run",
    "bridge:pipeline": "node scripts/github-agent-bridge.mjs process-pipeline",
    "check:agent-bridge": "node scripts/check-agent-bridge-core.mjs",
    "check:agent-bridge:review": "node scripts/check-agent-bridge-review-flow.mjs",
    "context:budget": "node scripts/context-budget.mjs",
    "context:check": "node scripts/context-budget.mjs --check",
    "lint": "echo 'Linting not configured'",
    "preview": "vite preview",
    "clean": "./scripts/cleanup_dev_env.sh",
    "check:prompt-master": "node scripts/check-prompt-master.mjs",
    "check:mission-goals": "node scripts/check-mission-goals.mjs",
    "check:mission-registration": "node scripts/mission-registration-preflight.mjs",
    "check:j2p2-workability": "node scripts/check-j2p2-workability-contract.mjs",
    "check:prompt-master:visual": "node scripts/chrome-prompt-master-qa.mjs",
    "check:image-generation": "node scripts/check-image-generation.mjs",
    "check:legal": "node scripts/check-legal-claims.mjs",
    "check:postmarket": "node scripts/check-post-market-monitoring.mjs",
    "check:ai-provider-docs": "node scripts/check-ai-provider-docs.mjs",
    "check:ai-usage": "node scripts/check-ai-usage-telemetry.mjs && node scripts/check-mistral-bfl-providers.mjs",
    "check:rls:functions": "node scripts/check-rls-functions.mjs",
    "check:rls:throwaway": "node scripts/check-rls-throwaway.mjs",
    "check:supabase:remote-migrations": "node scripts/check-supabase-remote-migrations.mjs",
    "biastest": "node scripts/biastest.mjs",
    "edge:serve:function": "node scripts/serve-edge-function.mjs",
    "edge:serve:gdrive-backup": "node scripts/serve-edge-function.mjs gdrive-backup",
    "hooks:test": "node scripts/agent-hooks/test-agent-hooks.mjs && node scripts/agent-hooks/verify-agent-hooks.mjs",
    "typecheck": "npm run typecheck:app",
    "typecheck:app": "tsc -p tsconfig.app.json --noEmit",
    "typecheck:edge": "tsc -p tsconfig.edge-functions.json --noEmit",
    "doctor": "echo '🩺 Checking critical app paths...' && npx tsc -p tsconfig.critical.json --noEmit && echo '✅ Critical TypeScript Check OK'",
    "doctor:full": "echo '🩺 Checking app TypeScript...' && npm run typecheck:app && echo '🩺 Checking Edge Function TypeScript...' && npm run typecheck:edge && echo '✅ Full TypeScript Check OK'",
    "deploy": "vercel --prod",
    "lighthouse": "bash ./scripts/lighthouse-audit.sh",
    "lighthouse:parse": "node scripts/parse-lighthouse.js",
    "lighthouse:median": "node scripts/lighthouse-median-check.mjs",
    "perf:assert:network": "node scripts/assert-critical-route-network.mjs",
    "perf:bundle:check": "node scripts/check-bundle-budgets.mjs",
    "performance:ci": "npm run lighthouse:median && npm run perf:assert:network && npm run perf:bundle:check",
    "qa:journey:desktop": "node scripts/audit-journey-desktop.mjs",
    "audit:security": "npm audit --audit-level=moderate",
    "security:check": "node scripts/security-report-core-check.mjs && node scripts/check-website-security-posture.mjs",
    "postmarket:review": "node scripts/generate-post-market-review.mjs",
    "review:handoff": "node scripts/validate-claude-handoff.mjs"
  },
  "dependencies": {
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@supabase/supabase-js": "2.95.3",
    "@types/dompurify": "^3.0.5",
    "@types/three": "^0.182.0",
    "c2pa": "^0.30.17",
    "dompurify": "^3.4.11",
    "exceljs": "^4.4.0",
    "framer-motion": "^12.40.0",
    "gsap": "^3.15.0",
    "jspdf": "^4.2.0",
    "lucide-react": "^0.575.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-markdown": "^10.1.0",
    "three": "^0.184.0",
    "web-vitals": "^5.2.0"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "autoprefixer": "^10.5.0",
    "openai": "^6.44.0",
    "playwright": "^1.60.0",
    "postcss": "^8.5.6",
    "sharp": "^0.34.5",
    "tailwindcss": "^3.4.17",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "overrides": {
    "uuid": "^11.1.1"
  }
}
